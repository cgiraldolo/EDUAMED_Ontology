<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/highrisk-meddev-&amp;-invitrodev-diag#"
     xml:base="http://www.example.org/highrisk-meddev-&amp;-invitrodev-diag"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:meddevice="http://www.example.org/meddevice#">
    <owl:Ontology rdf:about="http://www.example.org/highrisk-meddev-&amp;-invitrodev-diag">
        <rdfs:comment xml:lang="es">Esta ontología modela de forma semántica el catálogo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro de la base de datos europea EUDAMED. Incluye dispositivos, fabricantes, riesgos identificados, incidentes y acciones correctivas de seguridad.</rdfs:comment>
        <rdfs:comment xml:lang="en">This ontology semantically models the catalogue of high-risk medical devices and in-vitro diagnostic devices of the EUDAMED european database. It includes devices, manufacturers, identified risks, incidents and corrective safety actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Ontology of the european catalogue of high-risk medical devices and in-vitro diagnostics devices.</rdfs:label>
        <rdfs:label xml:lang="es">Ontología del catálogo europeo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro.</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.example.org/meddevice#name -->


    <owl:AnnotationProperty rdf:about="http://www.example.org/meddevice#name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/meddevice#affectsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#affectsDeviceType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#DeviceType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#appliesToIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#appliesToIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Incident"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#isOfType -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#isOfType">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#DeviceType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#isSubclassifiedUnder -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#isSubclassifiedUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#registeredInCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#registeredInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Country"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#relatesToDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#relatesToDevice">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Device"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#relatesToRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#relatesToRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Risk"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#reportedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#reportedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/meddevice#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.example.org/meddevice#reportedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/meddevice#Country"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/Identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/Identifier"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://www.example.org/meddevice#correctiveActionActDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionActDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#correctiveActionClosureDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionClosureDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#correctiveActionCountriesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionCountriesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#correctiveActionDevicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionDevicesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#correctiveActionEudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionEudamedFscaRef">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#correctiveActionScope -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionScope">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#correctiveActionStatus -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#correctiveActionStatus">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#description -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#description">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/description"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceIntendedPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceIsActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceIsActive">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceIsImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceIsImplantable">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceIsIvd -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceIsIvd">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceIsReusable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceIsReusable">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceRegulatoryFramework -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceRiskClass -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceRiskClass">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#deviceUdiDi -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#deviceUdiDi">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#identifier -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#identifier">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/Identifier"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentCorrectiveActionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentCorrectiveActionTaken">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentDetectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentDetectionDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentEudamedRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentEudamedRef">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentEventDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentEventDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentOutcome -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentOutcome">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentPatientAge -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentPatientAge">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#incidentPatientSex -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentPatientSex"/>
    


    <!-- http://www.example.org/meddevice#incidentReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#incidentReportDate">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#manufacturerAuthNum -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#manufacturerAuthNum">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#manufacturerCompetentAuth -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#manufacturerCompetentAuth">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#manufacturerContactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#manufacturerContactEmail">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#manufacturerEudamedSm -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#manufacturerEudamedSm">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#name -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#name">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Device"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#riskCategory -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#riskCategory">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#riskImdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#riskImdrfCode">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#riskProbability -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#riskProbability">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/meddevice#riskSeverity -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/meddevice#riskSeverity">
        <rdfs:domain rdf:resource="http://www.example.org/meddevice#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://dbpedia.org/ontology/Country -->


    <owl:Class rdf:about="http://dbpedia.org/ontology/Country"/>
    


    <!-- http://www.example.org/meddevice#ContaminationRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#CorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/meddevice#CorrectiveAction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#appliesToIncident"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Country -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Country">
        <rdfs:subClassOf rdf:resource="http://dbpedia.org/ontology/Country"/>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Device -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Device">
        <rdfs:subClassOf rdf:resource="https://w3id.org/seas/Device"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#isOfType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#DeviceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#DeviceType -->


    <owl:Class rdf:about="http://www.example.org/meddevice#DeviceType"/>
    


    <!-- http://www.example.org/meddevice#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.example.org/meddevice#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#Risk"/>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#InSituCorrection -->


    <owl:Class rdf:about="http://www.example.org/meddevice#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.example.org/meddevice#CorrectiveAction"/>
    </owl:Class>
    


    <!-- http://www.example.org/meddevice#Incident -->


    <owl:Class rdf:about="http://www.example.org/meddevice#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#relatesToDevice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/meddevice#reportedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/meddevice#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
