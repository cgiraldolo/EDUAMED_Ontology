<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.cgiraldolo.com/highrisk-meddev-&amp;-invitrodev-diag#"
     xml:base="http://www.cgiraldolo.com/highrisk-meddev-&amp;-invitrodev-diag"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:invitrodev-diag="http://www.example.org/highrisk-meddev-&amp;-invitrodev-diag#">
    <owl:Ontology rdf:about="http://www.cgiraldolo.com/highrisk-meddev-&amp;-invitrodev-diag">
        <rdfs:comment xml:lang="es">Esta ontología modela de forma semántica el catálogo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro de la base de datos europea EUDAMED. Incluye dispositivos, fabricantes, riesgos identificados, incidentes y acciones correctivas de seguridad.</rdfs:comment>
        <rdfs:comment xml:lang="en">This ontology semantically models the catalogue of high-risk medical devices and in-vitro diagnostic devices of the EUDAMED european database. It includes devices, manufacturers, identified risks, incidents and corrective safety actions.</rdfs:comment>
        <rdfs:label xml:lang="en">Ontology of the european catalogue of high-risk medical devices and in-vitro diagnostics devices.</rdfs:label>
        <rdfs:label xml:lang="es">Ontología del catálogo europeo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro.</rdfs:label>
    </owl:Ontology>
    


