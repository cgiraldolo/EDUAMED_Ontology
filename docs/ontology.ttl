@prefix : <http://www.example.org/highrisk-meddev-&-invitrodev-diag#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.example.org/highrisk-meddev-&-invitrodev-diag#> .

<http://www.example.org/highrisk-meddev-&-invitrodev-diag> rdf:type owl:Ontology ;
                                                            rdfs:comment "Esta ontología modela de forma semántica el catálogo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro de la base de datos europea EUDAMED. Incluye dispositivos, fabricantes, riesgos identificados, incidentes y acciones correctivas de seguridad."@es ,
                                                                         "This ontology semantically models the catalogue of high-risk medical devices and in-vitro diagnostic devices of the EUDAMED european database. It includes devices, manufacturers, identified risks, incidents and corrective safety actions."@en ;
                                                            rdfs:label "Ontology of the european catalogue of high-risk medical devices and in-vitro diagnostics devices."@en ,
                                                                       "Ontología del catálogo europeo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro."@es .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.example.org/meddevice#name
<http://www.example.org/meddevice#name> rdf:type owl:AnnotationProperty ;
                                        rdfs:range xsd:string .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/meddevice#affectsDeviceType
<http://www.example.org/meddevice#affectsDeviceType> rdf:type owl:ObjectProperty ,
                                                              owl:FunctionalProperty ;
                                                     rdfs:domain <http://www.example.org/meddevice#Risk> ;
                                                     rdfs:range <http://www.example.org/meddevice#DeviceType> .


###  http://www.example.org/meddevice#appliesToIncident
<http://www.example.org/meddevice#appliesToIncident> rdf:type owl:ObjectProperty ,
                                                              owl:FunctionalProperty ,
                                                              owl:TransitiveProperty ;
                                                     rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                     rdfs:range <http://www.example.org/meddevice#Incident> .


###  http://www.example.org/meddevice#hasManufacturer
<http://www.example.org/meddevice#hasManufacturer> rdf:type owl:ObjectProperty ,
                                                            owl:FunctionalProperty ,
                                                            owl:TransitiveProperty ;
                                                   rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                   rdfs:range <http://www.example.org/meddevice#Manufacturer> .


###  http://www.example.org/meddevice#isOfType
<http://www.example.org/meddevice#isOfType> rdf:type owl:ObjectProperty ,
                                                     owl:FunctionalProperty ;
                                            rdfs:domain <http://www.example.org/meddevice#Device> ;
                                            rdfs:range <http://www.example.org/meddevice#DeviceType> .


###  http://www.example.org/meddevice#isSubclassifiedUnder
<http://www.example.org/meddevice#isSubclassifiedUnder> rdf:type owl:ObjectProperty ,
                                                                 owl:TransitiveProperty .


###  http://www.example.org/meddevice#registeredInCountry
<http://www.example.org/meddevice#registeredInCountry> rdf:type owl:ObjectProperty ,
                                                                owl:FunctionalProperty ;
                                                       rdfs:domain <http://www.example.org/meddevice#Manufacturer> ;
                                                       rdfs:range <http://www.example.org/meddevice#Country> .


###  http://www.example.org/meddevice#relatesToDevice
<http://www.example.org/meddevice#relatesToDevice> rdf:type owl:ObjectProperty ,
                                                            owl:FunctionalProperty ,
                                                            owl:TransitiveProperty ;
                                                   rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                   rdfs:range <http://www.example.org/meddevice#Device> .


###  http://www.example.org/meddevice#relatesToRisk
<http://www.example.org/meddevice#relatesToRisk> rdf:type owl:ObjectProperty ,
                                                          owl:FunctionalProperty ,
                                                          owl:TransitiveProperty ;
                                                 rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                 rdfs:range <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#reportedBy
<http://www.example.org/meddevice#reportedBy> rdf:type owl:ObjectProperty ,
                                                       owl:FunctionalProperty ,
                                                       owl:TransitiveProperty ;
                                              rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                              rdfs:range <http://www.example.org/meddevice#Manufacturer> .


###  http://www.example.org/meddevice#reportedInCountry
<http://www.example.org/meddevice#reportedInCountry> rdf:type owl:ObjectProperty ,
                                                              owl:FunctionalProperty ;
                                                     rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                     rdfs:range <http://www.example.org/meddevice#Country> .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/Identifier
<http://purl.org/dc/terms/Identifier> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:DatatypeProperty .


###  http://www.example.org/meddevice#correctiveActionActDate
<http://www.example.org/meddevice#correctiveActionActDate> rdf:type owl:DatatypeProperty ;
                                                           rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                           rdfs:range xsd:dateTime .


###  http://www.example.org/meddevice#correctiveActionClosureDate
<http://www.example.org/meddevice#correctiveActionClosureDate> rdf:type owl:DatatypeProperty ;
                                                               rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                               rdfs:range xsd:dateTime .


###  http://www.example.org/meddevice#correctiveActionCountriesAffected
<http://www.example.org/meddevice#correctiveActionCountriesAffected> rdf:type owl:DatatypeProperty ;
                                                                     rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                                     rdfs:range xsd:string .


###  http://www.example.org/meddevice#correctiveActionDevicesAffected
<http://www.example.org/meddevice#correctiveActionDevicesAffected> rdf:type owl:DatatypeProperty ;
                                                                   rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                                   rdfs:range xsd:integer .


###  http://www.example.org/meddevice#correctiveActionEudamedFscaRef
<http://www.example.org/meddevice#correctiveActionEudamedFscaRef> rdf:type owl:DatatypeProperty ;
                                                                  rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                                  rdfs:range xsd:string .


###  http://www.example.org/meddevice#correctiveActionScope
<http://www.example.org/meddevice#correctiveActionScope> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                         rdfs:range xsd:string .


###  http://www.example.org/meddevice#correctiveActionStatus
<http://www.example.org/meddevice#correctiveActionStatus> rdf:type owl:DatatypeProperty ;
                                                          rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ;
                                                          rdfs:range xsd:string .


###  http://www.example.org/meddevice#description
<http://www.example.org/meddevice#description> rdf:type owl:DatatypeProperty ;
                                               rdfs:subPropertyOf <http://purl.org/dc/terms/description> ;
                                               rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ,
                                                           <http://www.example.org/meddevice#Incident> ,
                                                           <http://www.example.org/meddevice#Risk> ;
                                               rdfs:range xsd:string .


###  http://www.example.org/meddevice#deviceIntendedPurpose
<http://www.example.org/meddevice#deviceIntendedPurpose> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                         rdfs:range xsd:string .


###  http://www.example.org/meddevice#deviceIsActive
<http://www.example.org/meddevice#deviceIsActive> rdf:type owl:DatatypeProperty ;
                                                  rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                  rdfs:range xsd:boolean .


###  http://www.example.org/meddevice#deviceIsImplantable
<http://www.example.org/meddevice#deviceIsImplantable> rdf:type owl:DatatypeProperty ;
                                                       rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                       rdfs:range xsd:boolean .


###  http://www.example.org/meddevice#deviceIsIvd
<http://www.example.org/meddevice#deviceIsIvd> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/meddevice#Device> ;
                                               rdfs:range xsd:boolean .


###  http://www.example.org/meddevice#deviceIsReusable
<http://www.example.org/meddevice#deviceIsReusable> rdf:type owl:DatatypeProperty ;
                                                    rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                    rdfs:range xsd:boolean .


###  http://www.example.org/meddevice#deviceRegulatoryFramework
<http://www.example.org/meddevice#deviceRegulatoryFramework> rdf:type owl:DatatypeProperty ;
                                                             rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                             rdfs:range xsd:string .


###  http://www.example.org/meddevice#deviceRiskClass
<http://www.example.org/meddevice#deviceRiskClass> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <http://www.example.org/meddevice#Device> ;
                                                   rdfs:range xsd:string .


###  http://www.example.org/meddevice#deviceUdiDi
<http://www.example.org/meddevice#deviceUdiDi> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/meddevice#Device> ;
                                               rdfs:range xsd:string .


###  http://www.example.org/meddevice#identifier
<http://www.example.org/meddevice#identifier> rdf:type owl:DatatypeProperty ;
                                              rdfs:subPropertyOf <http://purl.org/dc/terms/Identifier> ;
                                              rdfs:domain <http://www.example.org/meddevice#CorrectiveAction> ,
                                                          <http://www.example.org/meddevice#Device> ,
                                                          <http://www.example.org/meddevice#Incident> ,
                                                          <http://www.example.org/meddevice#Manufacturer> ,
                                                          <http://www.example.org/meddevice#Risk> ;
                                              rdfs:range xsd:string .


###  http://www.example.org/meddevice#incidentCorrectiveActionTaken
<http://www.example.org/meddevice#incidentCorrectiveActionTaken> rdf:type owl:DatatypeProperty ;
                                                                 rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                                 rdfs:range xsd:boolean .


###  http://www.example.org/meddevice#incidentDetectionDate
<http://www.example.org/meddevice#incidentDetectionDate> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                         rdfs:range xsd:dateTime .


###  http://www.example.org/meddevice#incidentEudamedRef
<http://www.example.org/meddevice#incidentEudamedRef> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                      rdfs:range xsd:string .


###  http://www.example.org/meddevice#incidentEventDate
<http://www.example.org/meddevice#incidentEventDate> rdf:type owl:DatatypeProperty ;
                                                     rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                     rdfs:range xsd:dateTime .


###  http://www.example.org/meddevice#incidentOutcome
<http://www.example.org/meddevice#incidentOutcome> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                   rdfs:range xsd:string .


###  http://www.example.org/meddevice#incidentPatientAge
<http://www.example.org/meddevice#incidentPatientAge> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                      rdfs:range xsd:integer .


###  http://www.example.org/meddevice#incidentPatientSex
<http://www.example.org/meddevice#incidentPatientSex> rdf:type owl:DatatypeProperty .


###  http://www.example.org/meddevice#incidentReportDate
<http://www.example.org/meddevice#incidentReportDate> rdf:type owl:DatatypeProperty ;
                                                      rdfs:domain <http://www.example.org/meddevice#Incident> ;
                                                      rdfs:range xsd:dateTime .


###  http://www.example.org/meddevice#manufacturerAuthNum
<http://www.example.org/meddevice#manufacturerAuthNum> rdf:type owl:DatatypeProperty ;
                                                       rdfs:domain <http://www.example.org/meddevice#Manufacturer> ;
                                                       rdfs:range xsd:string .


###  http://www.example.org/meddevice#manufacturerCompetentAuth
<http://www.example.org/meddevice#manufacturerCompetentAuth> rdf:type owl:DatatypeProperty ;
                                                             rdfs:domain <http://www.example.org/meddevice#Manufacturer> ;
                                                             rdfs:range xsd:string .


###  http://www.example.org/meddevice#manufacturerContactEmail
<http://www.example.org/meddevice#manufacturerContactEmail> rdf:type owl:DatatypeProperty ;
                                                            rdfs:domain <http://www.example.org/meddevice#Manufacturer> ;
                                                            rdfs:range xsd:string .


###  http://www.example.org/meddevice#manufacturerEudamedSm
<http://www.example.org/meddevice#manufacturerEudamedSm> rdf:type owl:DatatypeProperty ;
                                                         rdfs:domain <http://www.example.org/meddevice#Manufacturer> ;
                                                         rdfs:range xsd:string .


###  http://www.example.org/meddevice#name
<http://www.example.org/meddevice#name> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <http://www.example.org/meddevice#Device> ,
                                                    <http://www.example.org/meddevice#Manufacturer> ,
                                                    <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#riskCategory
<http://www.example.org/meddevice#riskCategory> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <http://www.example.org/meddevice#Risk> ;
                                                rdfs:range xsd:string .


###  http://www.example.org/meddevice#riskImdrfCode
<http://www.example.org/meddevice#riskImdrfCode> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <http://www.example.org/meddevice#Risk> ;
                                                 rdfs:range xsd:string .


###  http://www.example.org/meddevice#riskProbability
<http://www.example.org/meddevice#riskProbability> rdf:type owl:DatatypeProperty ;
                                                   rdfs:domain <http://www.example.org/meddevice#Risk> ;
                                                   rdfs:range xsd:string .


###  http://www.example.org/meddevice#riskSeverity
<http://www.example.org/meddevice#riskSeverity> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <http://www.example.org/meddevice#Risk> ;
                                                rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Country
<http://dbpedia.org/ontology/Country> rdf:type owl:Class .


###  http://www.example.org/meddevice#ContaminationRisk
<http://www.example.org/meddevice#ContaminationRisk> rdf:type owl:Class ;
                                                     rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#CorrectiveAction
<http://www.example.org/meddevice#CorrectiveAction> rdf:type owl:Class ;
                                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                      owl:onProperty <http://www.example.org/meddevice#appliesToIncident> ;
                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                      owl:onClass <http://www.example.org/meddevice#Incident>
                                                                    ] .


###  http://www.example.org/meddevice#Country
<http://www.example.org/meddevice#Country> rdf:type owl:Class ;
                                           rdfs:subClassOf <http://dbpedia.org/ontology/Country> .


###  http://www.example.org/meddevice#CybersecurityRisk
<http://www.example.org/meddevice#CybersecurityRisk> rdf:type owl:Class ;
                                                     rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#Device
<http://www.example.org/meddevice#Device> rdf:type owl:Class ;
                                          rdfs:subClassOf <https://w3id.org/seas/Device> ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.example.org/meddevice#hasManufacturer> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass <http://www.example.org/meddevice#Manufacturer>
                                                          ] ,
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.example.org/meddevice#isOfType> ;
                                                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                            owl:onClass <http://www.example.org/meddevice#DeviceType>
                                                          ] .


###  http://www.example.org/meddevice#DeviceType
<http://www.example.org/meddevice#DeviceType> rdf:type owl:Class .


###  http://www.example.org/meddevice#DiagnosticRisk
<http://www.example.org/meddevice#DiagnosticRisk> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#InSituCorrection
<http://www.example.org/meddevice#InSituCorrection> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.example.org/meddevice#CorrectiveAction> .


###  http://www.example.org/meddevice#Incident
<http://www.example.org/meddevice#Incident> rdf:type owl:Class ;
                                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.example.org/meddevice#relatesToDevice> ;
                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                              owl:onClass <http://www.example.org/meddevice#Device>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.example.org/meddevice#reportedBy> ;
                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                              owl:onClass <http://www.example.org/meddevice#Manufacturer>
                                                            ] ,
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.example.org/meddevice#reportedInCountry> ;
                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                              owl:onClass <http://www.example.org/meddevice#Country>
                                                            ] .


###  http://www.example.org/meddevice#InfectionRisk
<http://www.example.org/meddevice#InfectionRisk> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#InjuryRisk
<http://www.example.org/meddevice#InjuryRisk> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#InterferenceRisk
<http://www.example.org/meddevice#InterferenceRisk> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#MalfunctionRisk
<http://www.example.org/meddevice#MalfunctionRisk> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#Manufacturer
<http://www.example.org/meddevice#Manufacturer> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://xmlns.com/foaf/0.1/Organization> ,
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty <http://www.example.org/meddevice#registeredInCountry> ;
                                                                  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                  owl:onClass <http://www.example.org/meddevice#Country>
                                                                ] .


###  http://www.example.org/meddevice#MaterialRisk
<http://www.example.org/meddevice#MaterialRisk> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#NearMissIncident
<http://www.example.org/meddevice#NearMissIncident> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http://www.example.org/meddevice#Incident> .


###  http://www.example.org/meddevice#Recall
<http://www.example.org/meddevice#Recall> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://www.example.org/meddevice#CorrectiveAction> .


###  http://www.example.org/meddevice#Risk
<http://www.example.org/meddevice#Risk> rdf:type owl:Class .


###  http://www.example.org/meddevice#SafetyAlert
<http://www.example.org/meddevice#SafetyAlert> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.example.org/meddevice#CorrectiveAction> .


###  http://www.example.org/meddevice#SeriousIncident
<http://www.example.org/meddevice#SeriousIncident> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.example.org/meddevice#Incident> .


###  http://www.example.org/meddevice#SoftwareRisk
<http://www.example.org/meddevice#SoftwareRisk> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.example.org/meddevice#Risk> .


###  http://www.example.org/meddevice#UserNotice
<http://www.example.org/meddevice#UserNotice> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.example.org/meddevice#CorrectiveAction> .


###  http://xmlns.com/foaf/0.1/Organization
<http://xmlns.com/foaf/0.1/Organization> rdf:type owl:Class .


###  https://w3id.org/seas/Device
<https://w3id.org/seas/Device> rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://www.example.org/meddevice#ContaminationRisk
<http://www.example.org/meddevice#ContaminationRisk> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#CorrectiveAction
<http://www.example.org/meddevice#CorrectiveAction> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#Country
<http://www.example.org/meddevice#Country> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#CybersecurityRisk
<http://www.example.org/meddevice#CybersecurityRisk> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#DEV-001
<http://www.example.org/meddevice#DEV-001> rdf:type owl:NamedIndividual ,
                                                    <http://www.example.org/meddevice#Device> ;
                                           <http://www.example.org/meddevice#hasManufacturer> <http://www.example.org/meddevice#MAN-001> ;
                                           <http://www.example.org/meddevice#isOfType> <http://www.example.org/meddevice#ImplantableActiveDevice> ;
                                           <http://www.example.org/meddevice#deviceIntendedPurpose> "Ventricular assist device for end-stage heart failure"@en ;
                                           <http://www.example.org/meddevice#deviceIsActive> "true"^^xsd:boolean ;
                                           <http://www.example.org/meddevice#deviceIsImplantable> "true"^^xsd:boolean ;
                                           <http://www.example.org/meddevice#deviceIsIvd> "false"^^xsd:boolean ;
                                           <http://www.example.org/meddevice#deviceIsReusable> "false"^^xsd:boolean ;
                                           <http://www.example.org/meddevice#deviceRegulatoryFramework> "MDR"@en ;
                                           <http://www.example.org/meddevice#deviceRiskClass> "ClassIII"@en ;
                                           <http://www.example.org/meddevice#deviceUdiDi> "(01)00380740009095"@en ;
                                           <http://www.example.org/meddevice#name> "HeartMate 3 LVAD"@en .


###  http://www.example.org/meddevice#Device
<http://www.example.org/meddevice#Device> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#DeviceType
<http://www.example.org/meddevice#DeviceType> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#DiagnosticRisk
<http://www.example.org/meddevice#DiagnosticRisk> rdf:type owl:NamedIndividual .


###  http://www.example.org/meddevice#FSCA-001
<http://www.example.org/meddevice#FSCA-001> rdf:type owl:NamedIndividual ,
                                                     <http://www.example.org/meddevice#SafetyAlert> ;
                                            <http://www.example.org/meddevice#appliesToIncident> <http://www.example.org/meddevice#INC-001> ;
                                            <http://www.example.org/meddevice#correctiveActionActDate> "2024-02-01T00:00:00"@en ;
                                            <http://www.example.org/meddevice#correctiveActionCountriesAffected> "EU-wide"@en ;
                                            <http://www.example.org/meddevice#correctiveActionDevicesAffected> 850 ;
                                            <http://www.example.org/meddevice#correctiveActionEudamedFscaRef> "EU-FSCA-2024-000001"@en ;
                                            <http://www.example.org/meddevice#correctiveActionScope> "All HeartMate 3 LVAD units implanted since 2020"@en ;
                                            <http://www.example.org/meddevice#correctiveActionStatus> "Open"@en ;
                                            <http://www.example.org/meddevice#description> "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0."@en .


