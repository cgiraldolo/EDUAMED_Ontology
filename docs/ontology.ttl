#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Country
<http://dbpedia.org/ontology/Country> rdf:type owl:Class .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#ContaminationRisk
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#ContaminationRisk> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Risk> .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#CorrectiveAction
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#CorrectiveAction> rdf:type owl:Class ;
                                                                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://www.example.org/highrisk-meddev-&-invitrodev-diag#appliesToIncident> ;
                                                                                              owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                              owl:onClass <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Incident>
                                                                                            ] .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#Country
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#Country> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <http://dbpedia.org/ontology/Country> .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#CybersecurityRisk
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#CybersecurityRisk> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Risk> .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#Device
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#Device> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <https://w3id.org/seas/Device> ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://www.example.org/highrisk-meddev-&-invitrodev-diag#hasManufacturer> ;
                                                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                    owl:onClass <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Manufacturer>
                                                                                  ] ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty <http://www.example.org/highrisk-meddev-&-invitrodev-diag#isOfType> ;
                                                                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                    owl:onClass <http://www.example.org/highrisk-meddev-&-invitrodev-diag#DeviceType>
                                                                                  ] .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#DeviceType
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#DeviceType> rdf:type owl:Class .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#DiagnosticRisk
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#DiagnosticRisk> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Risk> .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#InSituCorrection
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#InSituCorrection> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <http://www.example.org/highrisk-meddev-&-invitrodev-diag#CorrectiveAction> .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#Incident
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#Incident> rdf:type owl:Class ;
                                                                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://www.example.org/highrisk-meddev-&-invitrodev-diag#relatesToDevice> ;
                                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                      owl:onClass <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Device>
                                                                                    ] ,
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://www.example.org/highrisk-meddev-&-invitrodev-diag#reportedBy> ;
                                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                      owl:onClass <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Manufacturer>
                                                                                    ] ,
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://www.example.org/highrisk-meddev-&-invitrodev-diag#reportedInCountry> ;
                                                                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                                      owl:onClass <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Country>
                                                                                    ] .


###  http://www.example.org/highrisk-meddev-&-invitrodev-diag#InfectionRisk
<http://www.example.org/highrisk-meddev-&-invitrodev-diag#InfectionRisk> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <http://www.example.org/highrisk-meddev-&-invitrodev-diag#Risk> .


