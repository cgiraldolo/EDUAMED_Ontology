                                           <http://www.example.org/meddevice#incidentDetectionDate> "2024-01-10T00:00:00"^^xsd:dateTime ;
                                           <http://www.example.org/meddevice#incidentEudamedRef> "EU-INC-2024-000001"@en ;
                                           <http://www.example.org/meddevice#incidentEventDate> "2024-01-08T00:00:00"^^xsd:dateTime ;
                                           <http://www.example.org/meddevice#incidentOutcome> "Serious patient injury - embolic stroke"@en ;
                                           <http://www.example.org/meddevice#incidentPatientAge> 58 ;
                                           <http://www.example.org/meddevice#incidentPatientSex> "Male"@en ;
                                           <http://www.example.org/meddevice#incidentReportDate> "2024-01-15T00:00:00"^^xsd:dateTime .


