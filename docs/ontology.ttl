#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Country
<http://dbpedia.org/ontology/Country> rdf:type owl:Class .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty :respondsToIncident ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass :Incident
                                  ] .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf <http://dbpedia.org/ontology/Country> .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf <https://w3id.org/seas/Device> ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isOfType ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :DeviceType
                        ] .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#DeviceType
:DeviceType rdf:type owl:Class .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :occurredToDevice ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Device
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportedBy ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Manufacturer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportedInCountry ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Country
                          ] .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf <http://xmlns.com/foaf/0.1/Organization> ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :registeredInCountry ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :Country
                              ] .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Risk
:Risk rdf:type owl:Class .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :CorrectiveAction .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :CorrectiveAction .


###  http://xmlns.com/foaf/0.1/Organization
<http://xmlns.com/foaf/0.1/Organization> rdf:type owl:Class .


###  https://w3id.org/seas/Device
<https://w3id.org/seas/Device> rdf:type owl:Class .


