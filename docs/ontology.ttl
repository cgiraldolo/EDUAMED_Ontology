:CybersecurityRisk rdf:type owl:NamedIndividual .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ,
                  :Device ;
         :hasManufacturer :MAN-001 ;
         :isOfType :ImplantableActiveDevice ;
         :deviceIntendedPurpose "Ventricular assist device for end-stage heart failure"@en ;
         :deviceIsActive "true"^^xsd:boolean ;
         :deviceIsImplantable "true"^^xsd:boolean ;
         :deviceIsIvd "false"^^xsd:boolean ;
         :deviceIsReusable "false"^^xsd:boolean ;
         :deviceRegulatoryFramework "MDR" ;
         :deviceRiskClass "ClassIII" ;
         :deviceUdiDi "(01)00380740009095" ;
         :identifier "DEV-001" ;
         :name "HeartMate 3 LVAD"@en .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Device
:Device rdf:type owl:NamedIndividual .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#DeviceType
:DeviceType rdf:type owl:NamedIndividual .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#DiagnosticRisk
:DiagnosticRisk rdf:type owl:NamedIndividual .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :SafetyAlert ;
          :respondsToIncident :INC-001 ;
          :correctiveActionActDate "2024-02-01T00:00:00"^^xsd:dateTime ;
          :correctiveActionCountriesAffected "EU-wide" ;
          :correctiveActionDevicesAffected 850 ;
          :correctiveActionEudamedFscaRef "EU-FSCA-2024-000001" ;
          :correctiveActionScope "All HeartMate 3 LVAD units implanted since 2020"@en ;
          :correctiveActionStatus "Open"@en ;
          :description "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce device thrombosis risk. INR target range revised to 2.0–3.0."@en ;
          :identifier "FSCA-001" .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#Germany
:Germany rdf:type owl:NamedIndividual ,
                  :Country ;
         :identifier "Germany" ;
         :name "Germany"@en .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#INC-001
:INC-001 rdf:type owl:NamedIndividual ,
                  :SeriousIncident ;
         :isManifestationOfRisk :RSK-003 ;
         :occurredToDevice :DEV-001 ;
         :reportedBy :MAN-001 ;
         :reportedInCountry :Germany ;
         :description "Patient implanted with HeartMate 3 LVAD developed ischemic stroke 6 months post-implant. Device thrombus confirmed by echocardiography."@en ;
         :identifier "INC-001" ;
         :incidentCorrectiveActionTaken "true"^^xsd:boolean ;
         :incidentDetectionDate "2024-01-10T00:00:00"^^xsd:dateTime ;
         :incidentEudamedRef "EU-INC-2024-000001" ;
         :incidentEventDate "2024-01-08T00:00:00"^^xsd:dateTime ;
         :incidentOutcome "Serious patient injury - embolic stroke"@en ;
         :incidentPatientAge 58 ;
         :incidentPatientSex "Male"@en ;
         :incidentReportDate "2024-01-15T00:00:00"^^xsd:dateTime .


