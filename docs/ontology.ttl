#################################################################
#    Annotations
#################################################################

:ContaminationRisk rdfs:comment "Type of Risk affecting product quality"@en ;
                   rdfs:label "Contamination Risk"@en .


:CorrectiveAction rdfs:comment "Action taken to correct incident"@en ;
                  rdfs:label "Corrective Action"@en .


:Country rdfs:comment "Country identified by its english name"@en ;
         rdfs:label "Country"@en .


:CybersecurityRisk rdfs:comment "Type of Risk affecting device safety"@en ;
                   rdfs:label "CyberSecurity Risk"@en .


:Device rdfs:comment "High Risk Medical Device or In-Vitro Diagnostics Device"@en ;
        rdfs:label "Device"@en .


:DeviceType rdfs:comment "Type of device (ClassI, ClassIIa, ClassIIb and ClassIII for High Risk Medical Devices & ClassA, ClassB, ClassC and ClassD for In-Vitro Diagnostics Devices)"@en ;
            rdfs:label "Device Type"@en .


:DiagnosticRisk rdfs:comment "Type of Risk affecting diagnostic results"@en ;
                rdfs:label "Diagnostic Risk"@en .


:InSituCorrection rdfs:comment "Type of Corrective Action: performed on location"@en ;
                  rdfs:label "In Situ Correction"@en .


:Incident rdfs:comment "Incident related to Medical Device"@en ;
          rdfs:label "Incident"@en .


:InfectionRisk rdfs:comment "Type of Risk affecting patient's health"@en ;
               rdfs:label "Infection Risk"@en .


:InjuryRisk rdfs:comment "Type of Risk affecting patient's health"@en ;
            rdfs:label "Injury Risk"@en .


:InterferenceRisk rdfs:comment "Type of Risk affecting device performance"@en ;
                  rdfs:label "Interference Risk"@en .


:MalfunctionRisk rdfs:comment "Type of Risk affecting device performance"@en ;
                 rdfs:label "Malfunction Risk"@en .


:Manufacturer rdfs:comment "Manufacturing Organization of Medical Device"@en ;
              rdfs:label "Manufacturer"@en .


:MaterialRisk rdfs:comment "Type of Risk affecting patient's health"@en ;
              rdfs:label "Material Risk"@en .


:NearMissIncident rdfs:comment "Type of Incident by severity"@en ;
                  rdfs:label "Near Miss Incident"@en .


:Recall rdfs:comment "Type of Corrective Action: product recall"@en ;
        rdfs:label "Recall"@en .


:Risk rdfs:comment "Medical Risks associated to Medical Devices"@en ;
      rdfs:label "Risk"@en .


:SafetyAlert rdfs:comment "Type of Corrective Action: safety alert sent"@en ;
             rdfs:label "Safety Alert"@en .


:SeriousIncident rdfs:comment "Type of Incident by severity"@en ;
                 rdfs:label "Serious Incident"@en .


:SoftwareRisk rdfs:comment "Type of Risk affecting device performance"@en ;
              rdfs:label "Software Risk"@en .


:UserNotice rdfs:comment "Type of Corrective Action: notice sent to user(s)"@en ;
            rdfs:label "User Notice"@en .


:affectsDeviceType rdfs:comment "Device Types affected by Risk"@en ;
                   rdfs:label "affects device type"@en .


:correctiveActionActDate rdfs:comment "Date in which the action was taken"@en ;
                         rdfs:label "Corrective Action Action Date"@en .


:correctiveActionClosureDate rdfs:comment "Date in which the action was closed"@en ;
                             rdfs:label "Corrective Action Closure Date"@en .


:correctiveActionCountriesAffected rdfs:comment "Countries affected by the Corrective Action"@en ;
                                   rdfs:label "Corrective Action Countries Affected"@en .


:correctiveActionDevicesAffected rdfs:comment "Amount of Devices affected by the Corrective Action"@en ;
                                 rdfs:label "Corrective Action Devices Affected"@en .


:correctiveActionEudamedFscaRef rdfs:comment "Reference of the Corrective Action in the EUDAMED european database"@en ;
                                rdfs:label "Corrective Action Eudamed FSCA Reference"@en .


:correctiveActionScope rdfs:comment "Scope of the Corrective Action in terms of What devices were affected"@en ;
                       rdfs:label "Corrective Action Scope"@en .


:correctiveActionStatus rdfs:comment "Status of the Corrective Action (Open/Closed)"@en ;
                        rdfs:label "Corrective Action Status"@en .


:description rdfs:comment "Description of the term"@en ;
             rdfs:label "Description"@en .


:deviceIntendedPurpose rdfs:comment "Intended purpose of the Device"@en ;
                       rdfs:label "Device Intended Purpose"@en .


:deviceIsActive rdfs:comment "Is the Device currently active? (true/false)"@en ;
                rdfs:label "Device Is Active"@en .


:deviceIsImplantable rdfs:comment "Is the Device implantable? (true/false)"@en ;
                     rdfs:label "Device Is Implantable"@en .


:deviceIsIvd rdfs:comment "Is the Device an In-Vitro Diagnostics Device? (true/false)"@en ;
             rdfs:label "Device Is IVD"@en .


:deviceIsReusable rdfs:comment "Is the Device reusable? (true/false)"@en ;
                  rdfs:label "Device Is Reusable"@en .


:deviceRegulatoryFramework rdfs:comment "Regulatory Framework of the Device"@en ;
                           rdfs:label "Device Regulatory Framework"@en .


:deviceRiskClass rdfs:comment "Risk Class of the Device (I, IIa, IIb, III)"@en ;
                 rdfs:label "Device Risk Class"@en .


:deviceUdiDi rdfs:comment "UDI DI of the Device"@en ;
             rdfs:label "Device UDI DI"@en .


:hasManufacturer rdfs:comment "Manufacturer of a Medical Device"@en ;
                 rdfs:label "has manufacturer"@en .


:identifier rdfs:comment "Identifier string of the term"@en ;
            rdfs:label "Identifier"@en .


:incidentCorrectiveActionTaken rdfs:comment "Was a Corrective Action taken in regards to this Incident? (true/false)"@en ;
                               rdfs:label "Incident Corrective Action Taken"@en .


:incidentDetectionDate rdfs:comment "Date in which the Incident was detected"@en ;
                       rdfs:label "Incident Detection Date"@en .


:incidentEudamedRef rdfs:comment "Incident reference in the EUDAMED database"@en ;
                    rdfs:label "Incident Eudamed Reference"@en .


:incidentEventDate rdfs:comment "Date in which the event reported in the Incident took place"@en ;
                   rdfs:label "Incident Event Date"@en .


:incidentOutcome rdfs:comment "Outcome of the incident"@en ;
                 rdfs:label "Incident Outcome"@en .


:incidentPatientAge rdfs:comment "Age of the patient involved in the incident"@en ;
                    rdfs:label "Incident Patient Age"@en .


:incidentPatientSex rdfs:comment "Sex of the patient involved in the Incident"@en ;
                    rdfs:label "Incident Patient Sex"@en .


:incidentReportDate rdfs:comment "Date in which the Incident was reported"@en ;
                    rdfs:label "Incident Report Date"@en .


:isManifestationOfRisk rdfs:comment "Risk that is manifested in the incident"@en ;
                       rdfs:label "is manifestation of risk"@en .


:isOfType rdfs:comment "Type of Medical Device"@en ;
          rdfs:label "is of type"@en .


:isSubclassifiedUnder rdfs:label "is subclassified under"@en .


:manufacturerAuthNum rdfs:comment "Authorization number of the Manufacturer"@en ;
                     rdfs:label "Manufacturer Authorization Number"@en .


:manufacturerCompetentAuth rdfs:comment "Organisation responsible of enforcing regulations on the Manufacturer"@en ;
                           rdfs:label "Manufacturer Competent Authority"@en .


:manufacturerContactEmail rdfs:comment "Contact email address of the Manufacturer"@en ;
                          rdfs:label "Manufacturer Contact Email"@en .


:manufacturerEudamedSm rdfs:comment "Manufacturer's SM in the EUDAMED database"@en ;
                       rdfs:label "Manufacturer Eudamed SM"@en .


:name rdfs:comment "Common name of the resource"@en ;
      rdfs:label "Name"@en .


:occurredToDevice rdfs:comment "Device involved in the Incident"@en ;
                  rdfs:label "occurred to device"@en .


:registeredInCountry rdfs:comment "Country Manufacturer is registered in"@en ;
                     rdfs:label "registered in country"@en .


:reportedBy rdfs:comment "Manufacturer that reported the Incident"@en ;
            rdfs:label "reported by"@en .


:reportedInCountry rdfs:comment "Country that the Incident was reported In"@en ;
                   rdfs:label "reported in country"@en .


:respondsToIncident rdfs:comment "Incident that a Corrective Action is taken in response to"@en ;
                    rdfs:label "responds to incident"@en .


:riskCategory rdfs:comment "Category of the Risk based on affected entity"@en ;
              rdfs:label "Risk Category"@en .


:riskImdrfCode rdfs:comment "IMDRF code of the Risk"@en ;
               rdfs:label "Risk IMDRF code"@en .


:riskProbability rdfs:comment "Probability of the Risk (Low/Medium/High)"@en ;
                 rdfs:label "Risk Probability"@en .


:riskSeverity rdfs:comment "Severity of the Risk (Moderate/Serious/Critical)"@en ;
              rdfs:label "Risk Severity"@en .


#################################################################
#    Rules
#################################################################

<http://www.example.org/highrisk-meddev-&-invitrodev-diag#i> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/highrisk-meddev-&-invitrodev-diag#r> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/highrisk-meddev-&-invitrodev-diag#d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/highrisk-meddev-&-invitrodev-diag#t> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/meddevice#d> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/meddevice#t> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/meddevice#i> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/meddevice#r> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

<http://www.example.org/meddevice#m> rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "S2" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :isOfType ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/meddevice#d> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/meddevice#t>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :occurredToDevice ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/meddevice#i> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/meddevice#d>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :affectsDeviceType ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/meddevice#r> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/meddevice#t>
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#classPredicate> :Incident ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/meddevice#i>
                                                                                      ] ;
                                                                            rdf:rest rdf:nil
                                                                          ]
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :isManifestationOfRisk ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/meddevice#i> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/meddevice#r>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "S1" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :occurredToDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/meddevice#i> ;
