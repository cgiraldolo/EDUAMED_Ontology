@prefix : <http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#> .

<http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag> rdf:type owl:Ontology ;
                                                               <http://purl.org/dc/terms/license> "https://creativecommons.org/publicdomain/zero/1.0/" ;
                                                               rdfs:comment "Esta ontología modela de forma semántica el catálogo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro de la base de datos europea EUDAMED. Incluye dispositivos, fabricantes, riesgos identificados, incidentes y acciones correctivas de seguridad."@es ,
                                                                            "This ontology semantically models the catalogue of high-risk medical devices and in-vitro diagnostic devices of the EUDAMED european database. It includes devices, manufacturers, identified risks, incidents and corrective safety actions."@en ;
                                                               rdfs:label "Ontology of the european catalogue of high-risk medical devices and in-vitro diagnostics devices."@en ,
                                                                          "Ontología del catálogo europeo de dispositivos médicos de alto riesgo y dispositivos de diagnóstico in vitro."@es .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#affectsDeviceType
:affectsDeviceType rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#isManifestationOfRisk
:isManifestationOfRisk rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range :Risk .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#isOfType
:isOfType rdf:type owl:ObjectProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Device ;
          rdfs:range :DeviceType .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#isSubclassifiedUnder
:isSubclassifiedUnder rdf:type owl:ObjectProperty .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#occurredToDevice
:occurredToDevice rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Incident ;
                  rdfs:range :Device .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#registeredInCountry
:registeredInCountry rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range :Country .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#reportedBy
:reportedBy rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Incident ;
            rdfs:range :Manufacturer .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#reportedInCountry
:reportedInCountry rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range :Country .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#respondsToIncident
:respondsToIncident rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range :Incident .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/Identifier
<http://purl.org/dc/terms/Identifier> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:DatatypeProperty .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionActDate
:correctiveActionActDate rdf:type owl:DatatypeProperty ;
                         rdfs:domain :CorrectiveAction ;
                         rdfs:range xsd:dateTime .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionClosureDate
:correctiveActionClosureDate rdf:type owl:DatatypeProperty ;
                             rdfs:domain :CorrectiveAction ;
                             rdfs:range xsd:dateTime .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionCountriesAffected
:correctiveActionCountriesAffected rdf:type owl:DatatypeProperty ;
                                   rdfs:domain :CorrectiveAction ;
                                   rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionDevicesAffected
:correctiveActionDevicesAffected rdf:type owl:DatatypeProperty ;
                                 rdfs:domain :CorrectiveAction ;
                                 rdfs:range xsd:integer .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionEudamedFscaRef
:correctiveActionEudamedFscaRef rdf:type owl:DatatypeProperty ;
                                rdfs:domain :CorrectiveAction ;
                                rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionScope
:correctiveActionScope rdf:type owl:DatatypeProperty ;
                       rdfs:domain :CorrectiveAction ;
                       rdfs:range rdfs:Literal .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#correctiveActionStatus
:correctiveActionStatus rdf:type owl:DatatypeProperty ;
                        rdfs:domain :CorrectiveAction ;
                        rdfs:range rdfs:Literal .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#description
:description rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://purl.org/dc/terms/description> ;
             rdfs:range rdfs:Literal .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceIntendedPurpose
:deviceIntendedPurpose rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Device ;
                       rdfs:range rdfs:Literal .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceIsActive
:deviceIsActive rdf:type owl:DatatypeProperty ;
                rdfs:domain :Device ;
                rdfs:range xsd:boolean .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceIsImplantable
:deviceIsImplantable rdf:type owl:DatatypeProperty ;
                     rdfs:domain :Device ;
                     rdfs:range xsd:boolean .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceIsIvd
:deviceIsIvd rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:boolean .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceIsReusable
:deviceIsReusable rdf:type owl:DatatypeProperty ;
                  rdfs:domain :Device ;
                  rdfs:range xsd:boolean .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceRegulatoryFramework
:deviceRegulatoryFramework rdf:type owl:DatatypeProperty ;
                           rdfs:domain :Device ;
                           rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceRiskClass
:deviceRiskClass rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#deviceUdiDi
:deviceUdiDi rdf:type owl:DatatypeProperty ;
             rdfs:domain :Device ;
             rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#identifier
:identifier rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/terms/Identifier> ;
            rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentCorrectiveActionTaken
:incidentCorrectiveActionTaken rdf:type owl:DatatypeProperty ;
                               rdfs:domain :Incident ;
                               rdfs:range xsd:boolean .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentDetectionDate
:incidentDetectionDate rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:dateTime .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentEudamedRef
:incidentEudamedRef rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentEventDate
:incidentEventDate rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range xsd:dateTime .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentOutcome
:incidentOutcome rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range rdfs:Literal .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentPatientAge
:incidentPatientAge rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:integer .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentPatientSex
:incidentPatientSex rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range rdfs:Literal .


###  http://www.cgiraldolo.com/highrisk-meddev-&-invitrodev-diag#incidentReportDate
:incidentReportDate rdf:type owl:DatatypeProperty ;
